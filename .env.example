# ── Data Source (swap to switch ERP) ──────────────────────────────────────────
# demo_odoo   = PostgreSQL with Odoo-format demo tables (default for local dev)
# demo_sap_s4 = PostgreSQL with SAP S/4 format tables
# odoo        = Live Odoo 17 ERP (XML-RPC)
DATA_SOURCE=demo_odoo

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/odoo_procurement_demo

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ── Odoo ERP (optional, only needed for DATA_SOURCE=odoo) ────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_procurement_demo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# ── Security ──────────────────────────────────────────────────────────────────
AUTH_REQUIRED=false
JWT_SECRET=change-this-to-a-strong-random-secret
ADMIN_RESET_TOKEN=change-this-to-a-random-token
ADMIN_API_TOKEN=change-this-to-a-random-token
PYTHONPATH=.
PORT=5000

# ── Sprint 8: OCR Service ────────────────────────────────────────────────────
# OCR_PROVIDER=regex          (default — no API key needed)
# OCR_PROVIDER=mindee         (requires MINDEE_API_KEY)
# MINDEE_API_KEY=

# ── Sprint 8: Email Delivery ─────────────────────────────────────────────────
# EMAIL_PROVIDER=mock         (default — logs to console)
# EMAIL_PROVIDER=sendgrid     (requires SENDGRID_API_KEY)
# SENDGRID_API_KEY=
# FROM_EMAIL=noreply@procure.ai

# ── Sprint 8: FX Rates ───────────────────────────────────────────────────────
# FX_PROVIDER=static          (default — hardcoded AED rates)
# FX_PROVIDER=database        (reads exchange_rates table)
# OPENEXCHANGERATES_APP_ID=

# ── Sprint 8: Vendor Sanctions ───────────────────────────────────────────────
# SANCTIONS_PROVIDER=local    (default — simple blocklist)
# OPENSANCTIONS_API_KEY=

# ── Sprint 9: Slack (not yet implemented) ────────────────────────────────────
# SLACK_ENABLED=false
# SLACK_BOT_TOKEN=xoxb-your-bot-token

# ── Sprint 9: Scheduler ─────────────────────────────────────────────────────
# SCHEDULER_EMAIL_SCAN_SEC=900
# SCHEDULER_ANOMALY_SEC=21600

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
