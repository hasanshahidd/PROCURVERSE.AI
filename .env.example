# Procure AI Environment Variables
OPENAI_API_KEY=your_openai_key_here
DATABASE_URL=postgresql://user:pass@host:5432/dbname
JWT_SECRET=change-this-to-a-strong-random-secret

# Application Settings
PYTHONPATH=.
PORT=5000

# Email notifications (Sprint 8)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=procurement@your-domain.com
SENDGRID_API_KEY=

# Slack integration (Sprint 9)
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APPROVAL_CHANNEL=#procurement-approvals
SLACK_FINANCE_CHANNEL=#finance-alerts

# FX rates (Sprint 8)
FX_API_KEY=

# Email inbox / IMAP (Sprint 9)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Sanctions (Sprint 8)
OFAC_CHECK_ENABLED=true

# Anomaly detection thresholds (Sprint 9)
ANOMALY_LARGE_INVOICE_USD=10000
ANOMALY_SPEND_SPIKE_RATIO=1.5
ANOMALY_PRICE_VARIANCE_PCT=0.20

# Background scheduler intervals (Sprint 9)
SCHEDULER_EMAIL_SCAN_SEC=900
SCHEDULER_ANOMALY_SEC=21600
SCHEDULER_INVENTORY_SEC=14400
SCHEDULER_CONTRACT_SEC=86400

# Security (Sprint 10)
AUTH_REQUIRED=false
FRONTEND_URL=https://procure-ai-frontend.onrender.com
